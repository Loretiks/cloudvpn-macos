<?xml version="1.0" encoding="UTF-8"?>
<!-- LaunchDaemon spec, embedded into the helper (__launchd_plist section) and shipped
     in the app bundle at Contents/Library/LaunchDaemons/<Label>.plist for SMAppService.
     The filename MUST equal "<Label>.plist". -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>tech.cloude.vpn.mac.helper</string>
    <key>BundleProgram</key>
    <string>Contents/MacOS/tech.cloude.vpn.mac.helper</string>
    <key>MachServices</key>
    <dict>
        <key>tech.cloude.vpn.mac.helper</key>
        <true/>
    </dict>
    <key>AssociatedBundleIdentifiers</key>
    <array>
        <string>tech.cloude.vpn.mac</string>
    </array>
</dict>
</plist>
